# Copy to `.env` (and add `.env` to .gitignore) before running.

# Optional. If set, AI uses Anthropic Claude. If unset, falls back to Ollama.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Ollama settings — used when no Anthropic key, or when LLM_BACKEND=ollama.
# OLLAMA_URL=http://localhost:11434/api/chat
# OLLAMA_MODEL=llama3.2:3b

# Force a backend regardless of key presence: 'anthropic' or 'ollama'.
# LLM_BACKEND=ollama
